---
import members from '../data/members.json';
import parties from '../data/parties.json';
import sessions from '../data/sessions.json';
import ThingSelect from './ThingSelect.astro';
import { fmtTime, pct, url, type Member } from '../lib/util';

interface Props { lthing: number; }
const { lthing } = Astro.props;

interface PartySession {
  lthing: number; members: number; seats: number; speeches: number; seconds: number;
  ja: number; nei: number; sat_hja: number; bodadi_fjarvist: number;
  fjarverandi: number; maeting: number | null;
}
interface Party { id: number; heiti: string; skammstofun: string | null; thing: PartySession[]; }

const ss = sessions as { num: number; period: string }[];
const session = ss.find((s) => s.num === lthing)!;

const PALETTE = ['#1e4f8f', '#2c7a3f', '#b03030', '#8a5a2b', '#5b3a8f', '#1f7a78', '#b0762c', '#7a1f4e', '#4a6b1f', '#444'];

const mps = (members as Member[])
  .map((m) => ({ m, p: m.thing.find((p) => p.lthing === lthing) }))
  .filter((x): x is { m: Member; p: Member['thing'][number] } => x.p != null);

const topSpeakers = [...mps].filter((x) => x.p.seconds > 0).sort((a, b) => b.p.seconds - a.p.seconds);
const maxSpeakerSec = Math.max(...topSpeakers.map((x) => x.p.seconds), 1);

const topAttendance = [...mps]
  .filter((x) => x.p.tegund !== 'varamaður' && x.p.atkvaedi_alls >= 50)
  .sort((a, b) => (b.p.maeting ?? 0) - (a.p.maeting ?? 0));

const loyaltyPool = [...mps].filter(
  (x) => x.p.tegund !== 'varamaður' && x.p.ja + x.p.nei >= 50 && x.p.med_flokki != null
);
const mostLoyal = [...loyaltyPool].sort((a, b) => (b.p.med_flokki ?? 0) - (a.p.med_flokki ?? 0));
const leastLoyal = [...loyaltyPool].sort((a, b) => (a.p.med_flokki ?? 0) - (b.p.med_flokki ?? 0));

const partyRows = (parties as Party[])
  .map((f) => ({ f, p: f.thing.find((p) => p.lthing === lthing) }))
  .filter((x): x is { f: Party; p: PartySession } => x.p != null)
  .sort((a, b) => b.p.seconds - a.p.seconds);
const maxPartySec = Math.max(...partyRows.map((x) => x.p.seconds), 1);
const adal = mps.filter((x) => x.p.tegund && x.p.tegund !== 'varamaður').length;
const vara = mps.filter((x) => x.p.tegund === 'varamaður').length;
const seatRows = partyRows.filter((x) => x.p.seats > 0).sort((a, b) => b.p.seats - a.p.seats);
const maxPartySeats = Math.max(...seatRows.map((x) => x.p.seats), 1);

const trend = ss
  .map((s) => {
    const ps = (parties as Party[]).flatMap((f) => f.thing.filter((p) => p.lthing === s.num));
    return {
      num: s.num,
      period: s.period,
      seconds: ps.reduce((t, p) => t + p.seconds, 0),
      speeches: ps.reduce((t, p) => t + p.speeches, 0),
    };
  })
  .sort((a, b) => a.num - b.num);
const maxTrendSec = Math.max(...trend.map((t) => t.seconds), 1);
---
<div class="controls">
  <ThingSelect selected={lthing} basePath="/tolfraedi/" />
</div>
<p class="muted">{lthing}. löggjafarþing ({session.period})</p>

<h2>Ræðutími þingflokka</h2>
<table class="chart">
  <tbody>
    {partyRows.map(({ f, p }, i) => (
      <tr>
        <td class="label"><a href={url(`/flokkar/${f.id}/`)}>{f.heiti}</a></td>
        <td><div class="bar" title={`${f.heiti}: ${fmtTime(p.seconds)} í ${p.speeches.toLocaleString('is')} ræðum`}><span style={`width:${(p.seconds / maxPartySec) * 100}%;background:${PALETTE[i % PALETTE.length]}`}></span></div></td>
        <td class="num val">{fmtTime(p.seconds)}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Þingsæti eftir flokkum</h2>
<p class="muted">
  Sætaskipan við lok þingsins (63 sæti alls). Varamenn ekki taldir með.
  Alls sátu {mps.length} á þinginu: {adal} aðalmenn og {vara} varamenn sem tóku sæti tímabundið.
</p>
<table class="chart">
  <tbody>
    {seatRows.map(({ f, p }, i) => (
      <tr>
        <td class="label"><a href={url(`/flokkar/${f.id}/`)}>{f.heiti}</a></td>
        <td><div class="bar" title={`${f.heiti}: ${p.seats} þingsæti af 63`}><span style={`width:${(p.seats / maxPartySeats) * 100}%;background:${PALETTE[i % PALETTE.length]}`}></span></div></td>
        <td class="num val">{p.seats}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Mæting þingflokka í atkvæðagreiðslur</h2>
<table class="chart">
  <tbody>
    {[...partyRows].sort((a, b) => (b.p.maeting ?? 0) - (a.p.maeting ?? 0)).map(({ f, p }) => (
      <tr>
        <td class="label"><a href={url(`/flokkar/${f.id}/`)}>{f.heiti}</a></td>
        <td><div class="bar" title={`${f.heiti}: mæting ${pct(p.maeting)}`}><span style={`width:${(p.maeting ?? 0) * 100}%;background:var(--green)`}></span></div></td>
        <td class="num val">{pct(p.maeting)}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Mest töluðu þingmennirnir</h2>
<table class="chart">
  <tbody>
    {topSpeakers.map(({ m, p }, i) => (
      <tr class:list={[{ extra: i >= 15 }]}>
        <td class="label"><a href={url(`/thingmenn/${m.id}/`)}>{m.nafn}</a> <span class="muted">{p.flokkur ? `(${p.flokkur})` : ''}</span></td>
        <td><div class="bar" title={`${m.nafn}: ${fmtTime(p.seconds)} í ${p.speeches.toLocaleString('is')} ræðum`}><span style={`width:${(p.seconds / maxSpeakerSec) * 100}%`}></span></div></td>
        <td class="num val">{fmtTime(p.seconds)}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Besta mætingin (aðalmenn, a.m.k. 50 atkvæðagreiðslur)</h2>
<table class="chart">
  <tbody>
    {topAttendance.map(({ m, p }, i) => (
      <tr class:list={[{ extra: i >= 10 }]}>
        <td class="label"><a href={url(`/thingmenn/${m.id}/`)}>{m.nafn}</a> <span class="muted">{p.flokkur ? `(${p.flokkur})` : ''}</span></td>
        <td><div class="bar" title={`${m.nafn}: mæting ${pct(p.maeting)} (${p.atkvaedi_alls} atkvæðagreiðslur)`}><span style={`width:${(p.maeting ?? 0) * 100}%;background:var(--green)`}></span></div></td>
        <td class="num val">{pct(p.maeting)}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Flokkshollusta – kjósa oftast með eigin þingflokki</h2>
<p class="muted">Hlutfall já/nei-atkvæða sem féllu með meirihluta eigin þingflokks. Aðalmenn með a.m.k. 50 já/nei-atkvæði.</p>
<table class="chart">
  <tbody>
    {mostLoyal.map(({ m, p }, i) => (
      <tr class:list={[{ extra: i >= 10 }]}>
        <td class="label"><a href={url(`/thingmenn/${m.id}/`)}>{m.nafn}</a> <span class="muted">{p.flokkur ? `(${p.flokkur})` : ''}</span></td>
        <td><div class="bar" title={`${m.nafn}: ${pct(p.med_flokki)} með flokki (${p.ja + p.nei} já/nei-atkvæði)`}><span style={`width:${(p.med_flokki ?? 0) * 100}%;background:var(--accent)`}></span></div></td>
        <td class="num val">{pct(p.med_flokki)}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Flokkshollusta – kjósa sjaldnast með eigin þingflokki</h2>
<table class="chart">
  <tbody>
    {leastLoyal.map(({ m, p }, i) => (
      <tr class:list={[{ extra: i >= 10 }]}>
        <td class="label"><a href={url(`/thingmenn/${m.id}/`)}>{m.nafn}</a> <span class="muted">{p.flokkur ? `(${p.flokkur})` : ''}</span></td>
        <td><div class="bar" title={`${m.nafn}: ${pct(p.med_flokki)} með flokki (${p.ja + p.nei} já/nei-atkvæði)`}><span style={`width:${(p.med_flokki ?? 0) * 100}%;background:var(--red)`}></span></div></td>
        <td class="num val">{pct(p.med_flokki)}</td>
      </tr>
    ))}
  </tbody>
</table>

<h2>Þróun ræðutíma eftir þingum</h2>
<table class="chart">
  <tbody>
    {trend.map((t) => (
      <tr class:list={[{ current: t.num === lthing }]}>
        <td class="label"><a href={url(t.num === ss.reduce((m2, s) => Math.max(m2, s.num), 0) ? '/tolfraedi/' : `/tolfraedi/${t.num}/`)}>{t.num}. þing</a> <span class="muted">({t.period})</span></td>
        <td><div class="bar" title={`${t.num}. þing: ${fmtTime(t.seconds)} í ${t.speeches.toLocaleString('is')} ræðum`}><span style={`width:${(t.seconds / maxTrendSec) * 100}%`}></span></div></td>
        <td class="num val">{fmtTime(t.seconds)} · {t.speeches.toLocaleString('is')} ræður</td>
      </tr>
    ))}
  </tbody>
</table>

<script>
  // gerir gröfin gagnvirk: raða eftir gildi eða nafni, sýna allan listann
  for (const table of document.querySelectorAll('table.chart')) {
    const rows = [...table.querySelectorAll('tbody tr')];
    if (rows.length < 3) continue;
    const original = [...rows];
    const bar = document.createElement('div');
    bar.className = 'chart-controls';

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'chart-btn';
    btn.textContent = 'Raða eftir nafni';
    let byName = false;
    btn.addEventListener('click', () => {
      byName = !byName;
      btn.textContent = byName ? 'Raða eftir gildi' : 'Raða eftir nafni';
      btn.classList.toggle('active', byName);
      const tbody = table.querySelector('tbody');
      const ordered = byName
        ? [...rows].sort((a, b) =>
            (a.querySelector('.label')?.textContent ?? '').trim().localeCompare(
              (b.querySelector('.label')?.textContent ?? '').trim(), 'is'))
        : original;
      for (const r of ordered) tbody.appendChild(r);
    });
    bar.appendChild(btn);

    const extras = rows.filter((r) => r.classList.contains('extra'));
    if (extras.length > 0) {
      const more = document.createElement('button');
      more.type = 'button';
      more.className = 'chart-btn';
      let open = false;
      const visible = rows.length - extras.length;
      more.textContent = `Sýna alla (${rows.length})`;
      more.addEventListener('click', () => {
        open = !open;
        more.textContent = open ? `Sýna efstu ${visible}` : `Sýna alla (${rows.length})`;
        more.classList.toggle('active', open);
        for (const r of extras) r.classList.toggle('show', open);
      });
      bar.appendChild(more);
    }
    table.before(bar);
  }
</script>

<style>
  .chart td { border-bottom: none; padding: 0.25rem 0.6rem; }
  .chart tr:hover .bar { outline: 1px solid var(--ink); }
  .chart tr.extra { display: none; }
  .chart tr.extra.show { display: table-row; }
  .chart .label { width: 30%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 0; }
  .chart .val { width: 12rem; white-space: nowrap; }
  .chart .bar { height: 0.9rem; }
  .chart tr.current .label { font-weight: 700; }
  h2 { margin-top: 2.2rem; }
</style>

<style is:global>
  .chart-controls { display: flex; gap: 0.5rem; margin: 0.2rem 0 0.6rem; }
  .chart-btn {
    font: inherit; font-size: 0.78rem; font-weight: 500; color: var(--ink);
    background: #fff; border: 1px solid var(--line); border-radius: 999px;
    padding: 0.25rem 0.85rem; cursor: pointer;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .chart-btn:hover { border-color: var(--accent); color: var(--accent); }
  .chart-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
</style>
