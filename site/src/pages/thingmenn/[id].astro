---
import Base from '../../layouts/Base.astro';
import members from '../../data/members.json';
import sessions from '../../data/sessions.json';
import { memberTotals, latestSeat, fmtTime, pct, url, BASE, type Member } from '../../lib/util';

export function getStaticPaths() {
  return (members as Member[]).map((m) => ({ params: { id: String(m.id) }, props: { m } }));
}
const { m } = Astro.props as { m: Member };
const t = memberTotals(m);
const seat = latestSeat(m);
const maxSeconds = Math.max(...m.thing.map((p) => p.seconds), 1);
const latestThing = Math.max(...(sessions as { num: number }[]).map((s) => s.num));
const voteThings = [...m.thing].filter((p) => p.atkvaedi_alls > 0).map((p) => p.lthing).sort((a, b) => b - a);
---
<Base title={m.nafn}>
  <h1>{m.nafn}</h1>
  <p class="muted">
    {m.faedingardagur && <>f. {m.faedingardagur} · </>}
    {seat.flokkur && <span class="pill">{seat.flokkur}</span>}
    {seat.kjordaemi && <> {seat.kjordaemi}</>}
    · <a href={`https://www.althingi.is/altext/cv/is/?nfaerslunr=${m.id}`}>Æviágrip á althingi.is</a>
  </p>

  <div class="stat-grid">
    <div class="stat"><div class="v">{m.thing.length}</div><div class="l">löggjafarþing</div></div>
    <div class="stat"><div class="v">{t.speeches.toLocaleString('is')}</div><div class="l">ræður</div></div>
    <div class="stat"><div class="v">{fmtTime(t.seconds)}</div><div class="l">ræðutími samtals</div></div>
    <div class="stat"><div class="v">{pct(t.maeting)}</div><div class="l">mæting í atkvæðagreiðslur</div></div>
  </div>

  <h2>Eftir þingum</h2>
  <table>
    <thead>
      <tr>
        <th>Þing</th><th>Flokkur</th><th>Hlutverk</th>
        <th class="num">Ræður</th><th class="num">Ræðutími</th>
        <th class="num">Já</th><th class="num">Nei</th><th class="num">Sat hjá</th>
        <th class="num">Fjarvist</th><th class="num">Mæting</th><th class="num">Með flokki</th>
      </tr>
    </thead>
    <tbody>
      {[...m.thing].reverse().map((p) => (
        <tr>
          <td><a href={url(`/atkvaedagreidslur/${p.lthing}/`)}>{p.lthing}.</a></td>
          <td>{p.flokkur ?? '–'}</td>
          <td>{p.tegund ?? '–'}</td>
          <td class="num">{p.speeches.toLocaleString('is')}</td>
          <td class="num">{fmtTime(p.seconds)}</td>
          <td class="num v-ja">{p.ja}</td>
          <td class="num v-nei">{p.nei}</td>
          <td class="num v-hja">{p.sat_hja}</td>
          <td class="num">{p.bodadi_fjarvist + p.fjarverandi}</td>
          <td class="num">{pct(p.maeting)}</td>
          <td class="num">{pct(p.med_flokki)}</td>
        </tr>
      ))}
    </tbody>
  </table>
  <p class="muted">
    „Mæting“ = hlutfall atkvæðagreiðslna þar sem þingmaðurinn var viðstaddur (já, nei eða sat hjá).
    „Með flokki“ = hlutfall já/nei-atkvæða sem féllu með meirihluta eigin þingflokks.
  </p>

  {voteThings.length > 0 && (
    <>
      <h2>Atkvæði í einstökum málum</h2>
      <div class="controls">
        <label>
          <span class="muted">Löggjafarþing:</span>
          <select id="atkv-thing">
            {voteThings.map((lt) => <option value={lt}>{lt}. þing</option>)}
          </select>
        </label>
        <input type="search" id="atkv-leit" placeholder="Leita að máli…" />
      </div>
      <div id="atkv-listi" class="muted">Sæki gögn…</div>
      <script define:vars={{ mid: m.id, base: BASE, latestThing }}>
        const VOTE_LABEL = { j: 'já', n: 'nei', g: 'sat hjá', b: 'boðaði fjarvist', f: 'fjarverandi' };
        const VOTE_CLASS = { j: 'v-ja', n: 'v-nei', g: 'v-hja', b: 'muted', f: 'muted' };
        const sel = document.getElementById('atkv-thing');
        const leit = document.getElementById('atkv-leit');
        const out = document.getElementById('atkv-listi');
        const cache = {};

        function render() {
          const data = cache[sel.value];
          if (!data) return;
          const q = leit.value.toLowerCase().trim();
          const rows = data.atkvaedagreidslur.filter(
            (v) => v.atkv && v.atkv[mid] && (!q || (v.mal || '').toLowerCase().includes(q))
          );
          out.classList.remove('muted');
          out.innerHTML = '';
          const info = document.createElement('p');
          info.className = 'muted';
          info.textContent = `${rows.length} atkvæðagreiðslur með atkvæði þingmannsins`;
          out.appendChild(info);
          const table = document.createElement('table');
          const thead = document.createElement('thead');
          const hr = document.createElement('tr');
          for (const h of ['Dags.', 'Mál', 'Tegund', 'Atkvæði', 'Úrslit']) {
            const th = document.createElement('th');
            th.textContent = h;
            hr.appendChild(th);
          }
          thead.appendChild(hr);
          table.appendChild(thead);
          const tb = document.createElement('tbody');
          for (const v of rows.slice(0, 300)) {
            const tr = document.createElement('tr');
            const tdD = document.createElement('td');
            tdD.className = 'muted';
            tdD.style.whiteSpace = 'nowrap';
            tdD.textContent = v.timi ? v.timi.slice(0, 10) : '';
            const tdM = document.createElement('td');
            const a = document.createElement('a');
            a.href = `${base}/mal/${Number(sel.value) === latestThing ? '' : sel.value + '/'}#m${v.malsnr}`;
            a.textContent = v.mal ?? 'Óþekkt mál';
            tdM.appendChild(a);
            const tdT = document.createElement('td');
            tdT.className = 'muted';
            tdT.textContent = v.tegund ?? '';
            const tdA = document.createElement('td');
            const code = v.atkv[mid];
            tdA.className = VOTE_CLASS[code] ?? '';
            tdA.textContent = VOTE_LABEL[code] ?? code;
            const tdU = document.createElement('td');
            tdU.className = 'muted';
            tdU.textContent = `já ${v.ja ?? 0} – nei ${v.nei ?? 0} (${v.nidurstada ?? 'óþekkt'})`;
            tr.append(tdD, tdM, tdT, tdA, tdU);
            tb.appendChild(tr);
          }
          table.appendChild(tb);
          out.appendChild(table);
          if (rows.length > 300) {
            const more = document.createElement('p');
            more.className = 'muted';
            more.textContent = `Sýni fyrstu 300 af ${rows.length} — notaðu leitina til að þrengja.`;
            out.appendChild(more);
          }
        }

        function load() {
          const lt = sel.value;
          if (cache[lt]) return render();
          out.classList.add('muted');
          out.textContent = 'Sæki gögn…';
          fetch(`${base}/data/votes_${lt}.json`)
            .then((r) => r.json())
            .then((d) => { cache[lt] = d; render(); })
            .catch(() => (out.textContent = 'Ekki tókst að sækja gögn.'));
        }

        sel.addEventListener('change', load);
        leit.addEventListener('input', render);
        load();
      </script>
    </>
  )}

  <h2>Ræðutími eftir þingum</h2>
  <table>
    <tbody>
      {m.thing.map((p) => (
        <tr>
          <td style="width:4rem">{p.lthing}.</td>
          <td><div class="bar"><span style={`width:${(p.seconds / maxSeconds) * 100}%`}></span></div></td>
          <td class="num" style="width:8rem">{fmtTime(p.seconds)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
