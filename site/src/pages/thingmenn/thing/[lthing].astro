---
import Base from '../../../layouts/Base.astro';
import MemberDirectory from '../../../components/MemberDirectory.astro';
import sessions from '../../../data/sessions.json';

export function getStaticPaths() {
  const ss = sessions as { num: number }[];
  const latest = Math.max(...ss.map((s) => s.num));
  return ss
    .filter((s) => s.num !== latest)
    .map((s) => ({ params: { lthing: String(s.num) }, props: { lthing: s.num } }));
}
const { lthing } = Astro.props as { lthing: number };
---
<Base title={`Þingmenn – ${lthing}. þing`}>
  <h1>Þingmenn á {lthing}. þingi</h1>
  <p class="muted">Þingmenn á völdu löggjafarþingi ásamt tölfræði þess þings. Smelltu á nafn fyrir nánari upplýsingar.</p>
  <MemberDirectory lthing={lthing} />
</Base>
